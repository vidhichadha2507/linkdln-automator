{
  "version": 2,
  "builds": [
    {
      "src": "api/index.ts",
      "use": "@vercel/node",
      "config": {
        "includeFiles": "src/public/**"
      }
    }
  ],
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "api/index.ts"
    }
  ],
  "crons": [
    {
      "path": "/api/campaigns/tick",
      "schedule": "0 0 * * *"
    }
  ]
}
